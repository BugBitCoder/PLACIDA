# ============================================
# Placida — Environment Variables Template
# ============================================
# Copy this file to .env and fill in real values.
# The .env file is listed in .gitignore — NEVER commit it.
#
# These values go directly into the following files:
#   → frontend/supabase.js  (SUPABASE_URL + SUPABASE_ANON)
#   → frontend/features.js  (GEMINI_API_KEY)
# ============================================

# ── Supabase ──────────────────────────────
# Get from: supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=sb_publishable_your-anon-key-here

# ── Gemini AI ─────────────────────────────
# Get from: aistudio.google.com/app/apikey (free)
GEMINI_API_KEY=AIzaSy_your-key-here

# ── Notes ─────────────────────────────────
# Both keys are safe to use client-side.
# The Supabase anon key only allows access to public/RLS-protected data.
# The Gemini key can be restricted to your domain in Google Cloud Console.
